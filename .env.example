NEST_ENV=development

# DATABASE CONFIG
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_PORT=3306
DB_HOST=localhost

SERVER_PORT=3012
JWT_SECRET=
MASTER_PASSWORD=
AES_SECRET_KEY=

# Optional: enable nightly error log cleanup cron
RUN_CRON_JOBS=yes

# Redis (activity log queue; defaults to localhost:6379 if host omitted in app config)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_TLS=false

# MAILER
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=